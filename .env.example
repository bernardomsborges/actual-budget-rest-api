# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3010
TRUST_PROXY=true

# ============================================================================
# Authentication & Security
# ============================================================================
# Admin credentials for the API
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# Session and JWT secrets (must be at least 32 characters in production)
SESSION_SECRET=your_secure_session_secret_minimum_32_chars_long
JWT_SECRET=your_secure_jwt_secret_minimum_32_chars_long
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_minimum_32_chars_long

# JWT token expiration times (supported formats: 1h, 30m, 3600, etc.)
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=24h

# ============================================================================
# Actual Budget Integration
# ============================================================================
# URL of your Actual Budget server
ACTUAL_SERVER_URL=https://your-actual-server.com
# Password for Actual Budget server
ACTUAL_PASSWORD=your_actual_budget_password
# Sync ID for your Actual Budget account
ACTUAL_SYNC_ID=your_sync_id

# Data directory for Actual Budget cache
DATA_DIR=/app/.actual-cache

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3010,http://localhost:5678,https://your-frontend-domain.com

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis connection (used for rate limiting and caching)
# Option 1: Use Redis URL
# REDIS_URL=redis://default:your_redis_password@redis:6379

# Option 2: Use individual Redis connection settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_or_empty

# ============================================================================
# Database Configuration
# ============================================================================
# Database type: 'sqlite' or 'postgres'
DB_TYPE=sqlite

# PostgreSQL Configuration (only needed if DB_TYPE=postgres)
# Option 1: Use PostgreSQL URL
# POSTGRES_URL=postgresql://postgres:your_password@postgres:5432/actual_rest_api

# Option 2: Use individual PostgreSQL connection settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=actual_rest_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ============================================================================
# Security Features (Optional flags)
# ============================================================================
ENABLE_CORS=true
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true
MAX_REQUEST_SIZE=10kb
